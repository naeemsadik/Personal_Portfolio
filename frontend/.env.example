# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Keep snapshot rewrites disabled unless this deployment also contains the
# generated /__snapshots__ files.
ENABLE_SNAPSHOT_MIDDLEWARE=0
EMERGENCY_DISABLE_SNAPSHOT_MODE=0

# --- Backend (FastAPI) ---
# Public URL the browser uses to reach the API (uploads, public reads).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side fetch base. If unset, NEXT_PUBLIC_API_URL is used.
# Override this in production if the backend runs on a different host
# than the public URL (e.g. backend:8000 in compose).
API_INTERNAL_URL=http://localhost:8000

# --- Optional: contact-form email notifications ---
RESEND_API_KEY=
CONTACT_NOTIFY_TO=
