# Don't ship dev / build artifacts into the image. BuildKit reads
# this file at the start of every `docker build` and silently skips
# matching paths. Without it, `COPY . .` would copy `node_modules/`
# (huge, platform-specific binaries) and `.next/` (huge build output)
# from the host machine into the image, doubling the context size and
# frequently breaking the install.

node_modules/
.next/
.turbo/
.out/

# Local env files (real values come from Coolify at runtime).
.env
.env.local
.env.*.local

# TypeScript build info (can be megabytes).
*.tsbuildinfo

# Test / script logs.
bake.log
*.log

# Editor / OS junk.
.vscode/
.idea/
.DS_Store
Thumbs.db
