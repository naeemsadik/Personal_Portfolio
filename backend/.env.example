# --- Database ---
DATABASE_URL=mysql+pymysql://portfolio:portfolio@localhost:3306/portfolio

# --- JWT ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRE_MIN=15
JWT_ALGORITHM=HS256

# --- Bootstrap admin (used by `python -m app.seed` only) ---
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-on-first-login

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=8
# CV / resume PDFs can be larger than icon-sized images.
MAX_CV_UPLOAD_MB=10

# --- Public URL used to build absolute URLs returned to the client ---
# Must match where FastAPI is reachable from the browser.
PUBLIC_API_URL=http://localhost:8000