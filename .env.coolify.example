# --- Database (Coolify service env) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=portfolio
MYSQL_USER=portfolio
MYSQL_PASSWORD=

# --- Backend (Coolify service env) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_EXPIRE_MIN=60
ADMIN_BOOTSTRAP_EMAIL=[email protected]
ADMIN_BOOTSTRAP_PASSWORD=

# --- Frontend wiring ---
# The URL of your Next.js frontend (e.g. Vercel deployment).
NEXT_PUBLIC_SITE_URL=https://your-frontend-host
# Where the backend will be reachable from the browser.
# Set this to your public backend host (e.g. https://api.yourdomain.com).
PUBLIC_API_URL=https://api.your-backend-host
# Comma-separated origins allowed to call the API (CORS).
# Include both https and http variants of your frontend if needed.
CORS_ORIGINS=https://your-frontend-host

# --- Uploads ---
MAX_UPLOAD_MB=8
MAX_CV_UPLOAD_MB=10

# --- Optional: contact-form email notifications ---
RESEND_API_KEY=
CONTACT_NOTIFY_TO=
